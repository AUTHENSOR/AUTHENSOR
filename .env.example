# =============================================================================
# Authensor Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# All variables have sensible defaults for local self-hosted development.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# PostgreSQL connection string.
# Docker Compose sets this automatically for the control-plane container;
# override here if running outside Docker or using an external database.
DATABASE_URL=postgres://authensor:authensor_dev@localhost:5432/authensor

# Port the control plane listens on.
PORT=3000

# Node environment (development | staging | production).
NODE_ENV=development

# Docker Compose database credentials (used by the postgres container).
POSTGRES_USER=authensor
POSTGRES_PASSWORD=authensor_dev
POSTGRES_DB=authensor

# -----------------------------------------------------------------------------
# Bootstrap & Authentication
# -----------------------------------------------------------------------------

# Set on first run to auto-create an admin API key.
# The key will be printed to stdout on startup. Remove after bootstrapping.
# Generate with: openssl rand -base64 32
# AUTHENSOR_BOOTSTRAP_ADMIN_TOKEN=

# API key for MCP server to authenticate with the control plane.
# Generate via POST /keys with admin role, then set here.
# AUTHENSOR_API_KEY=authensor_your_generated_key_here

# -----------------------------------------------------------------------------
# Policy Engine
# -----------------------------------------------------------------------------

# If true, skips loading the default built-in policy.
# Only set this if you always upload your own policies.
AUTHENSOR_SKIP_DEFAULT_POLICY=false

# If true, allows a fallback allow-all policy when no active policy exists.
# WARNING: Only use in development. Production should fail-closed (false).
AUTHENSOR_ALLOW_FALLBACK_POLICY=false

# -----------------------------------------------------------------------------
# Execution Mode
# -----------------------------------------------------------------------------

# Sandbox mode: "stub" returns fake responses without making real API calls.
# "real" makes actual API calls to upstream services.
# Start with "stub" for safe testing.
# AUTHENSOR_SANDBOX_MODE=stub

# -----------------------------------------------------------------------------
# Approval Webhooks
# -----------------------------------------------------------------------------

# Webhook URL called when an action requires approval (POST with JSON payload).
# AUTHENSOR_APPROVAL_WEBHOOK_URL=https://your-webhook.example.com

# Shared secret sent as Authorization: Bearer <secret> to the approval webhook.
# AUTHENSOR_APPROVAL_WEBHOOK_SECRET=

# How long approval requests remain valid before auto-expiring (milliseconds).
# Default: 3600000 (1 hour).
AUTHENSOR_APPROVAL_EXPIRY_INTERVAL_MS=3600000

# -----------------------------------------------------------------------------
# Policy Alert Webhooks
# -----------------------------------------------------------------------------

# Webhook URL called when no active policy is configured (alerts on evaluate).
# AUTHENSOR_POLICY_ALERT_WEBHOOK_URL=https://your-webhook.example.com

# Shared secret for the policy alert webhook.
# AUTHENSOR_POLICY_ALERT_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Per-minute rate limits by role. Applies per API key per route group.
AUTHENSOR_RL_INGEST_PER_MIN=120
AUTHENSOR_RL_EXECUTOR_PER_MIN=60
AUTHENSOR_RL_ADMIN_PER_MIN=120

# Optional webhook called on first rate-limit hit per key+route+minute window.
# AUTHENSOR_RATE_LIMIT_WEBHOOK_URL=https://your-webhook.example.com

# Shared secret for the rate-limit webhook.
# AUTHENSOR_RATE_LIMIT_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Control Plane Settings
# -----------------------------------------------------------------------------

# Control plane URL (used by MCP server and SDKs to reach the control plane).
CONTROL_PLANE_URL=http://localhost:3000

# Claim TTL in seconds (how long an executor holds a claim lock).
AUTHENSOR_CLAIM_TTL_SECONDS=30

# Allow non-HTTPS requests in the HTTP tool (security risk; default false).
AUTHENSOR_ALLOW_HTTP=false

# -----------------------------------------------------------------------------
# Request/Response Size Limits
# -----------------------------------------------------------------------------

# Maximum request body size in bytes (default: 1MB).
AUTHENSOR_MAX_REQUEST_BYTES=1048576

# Maximum result size in bytes before truncation (default: 64KB).
AUTHENSOR_MAX_RESULT_BYTES=65536

# Maximum error size in bytes before truncation (default: 16KB).
AUTHENSOR_MAX_ERROR_BYTES=16384

# -----------------------------------------------------------------------------
# Integration Credentials (MCP Server)
# -----------------------------------------------------------------------------
# Only needed if running the MCP server with real integrations.

# Stripe (use test keys!)
# Get from: https://dashboard.stripe.com/test/apikeys
# STRIPE_TEST_KEY=sk_test_...
# Optional: live key (requires AUTHENSOR_STRIPE_ALLOW_LIVE=true)
# STRIPE_LIVE_KEY=
AUTHENSOR_STRIPE_ALLOW_LIVE=false
# Amount bounds (cents)
AUTHENSOR_STRIPE_MIN_AMOUNT=50
AUTHENSOR_STRIPE_MAX_AMOUNT=500000
# Comma-separated currency allowlist (lowercase)
AUTHENSOR_STRIPE_ALLOWED_CURRENCIES=usd
# Pin API version for deterministic behavior
STRIPE_API_VERSION=2023-10-16

# GitHub
# Get from: https://github.com/settings/tokens
# Scopes needed: repo, read:org (adjust based on tools you use)
# GITHUB_TOKEN=ghp_...
# Comma-separated allowlists. Empty = allow all in dev, deny all in prod.
AUTHENSOR_GITHUB_ALLOWED_REPOS=
AUTHENSOR_GITHUB_ALLOWED_ORGS=

# -----------------------------------------------------------------------------
# Optional: Observability
# -----------------------------------------------------------------------------
# LOG_LEVEL=debug
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
