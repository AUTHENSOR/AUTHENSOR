{
  "name": "@authensor/vercel-ai-sdk",
  "version": "0.0.1",
  "description": "Authensor guardrail adapter for Vercel AI SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@authensor/sdk": "workspace:*"
  },
  "peerDependencies": {
    "ai": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.1.0"
  },
  "keywords": [
    "authensor",
    "vercel",
    "vercel-ai-sdk",
    "ai-sdk",
    "guardrail",
    "ai-safety",
    "agent-safety",
    "agentic-ai",
    "action-authorization",
    "tool-governance",
    "policy-enforcement",
    "vercel-guardrail",
    "vercel-safety"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/authensor/authensor",
    "directory": "adapters/vercel-ai-sdk"
  },
  "homepage": "https://github.com/authensor/authensor",
  "publishConfig": {
    "access": "public"
  }
}
