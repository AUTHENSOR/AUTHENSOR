{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "gen"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["gen"],
      "outputs": []
    },
    "gen": {
      "outputs": ["src/generated/**"],
      "inputs": ["../schemas/src/**/*.schema.json"]
    },
    "clean": {
      "cache": false
    }
  }
}
