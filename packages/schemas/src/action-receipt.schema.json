{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://authensor.dev/schemas/action-receipt.schema.json",
  "title": "ActionReceipt",
  "description": "An action receipt records the outcome of an action that was evaluated and potentially executed.",
  "type": "object",
  "required": ["id", "envelopeId", "timestamp", "decision", "status"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this receipt"
    },
    "envelopeId": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the original action envelope"
    },
    "parentReceiptId": {
      "type": "string",
      "format": "uuid",
      "description": "Receipt ID of the parent action for cross-agent chain tracing"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the receipt was created"
    },
    "decision": {
      "type": "object",
      "description": "Policy evaluation decision",
      "required": ["outcome", "evaluatedAt"],
      "properties": {
        "outcome": {
          "type": "string",
          "enum": ["allow", "deny", "require_approval", "rate_limited"],
          "description": "Decision outcome"
        },
        "evaluatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the policy was evaluated"
        },
        "policyId": {
          "type": "string",
          "description": "ID of the policy that made the decision"
        },
        "policyVersion": {
          "type": "string",
          "description": "Version of the policy used"
        },
        "reason": {
          "type": "string",
          "description": "Human-readable reason for the decision"
        },
        "matchedRules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ruleId": { "type": "string" },
              "ruleName": { "type": "string" },
              "effect": { "type": "string", "enum": ["allow", "deny"] }
            }
          },
          "description": "Rules that matched during evaluation"
        }
      }
    },
    "approval": {
      "type": "object",
      "description": "Approval details if decision was require_approval",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "expired"],
          "description": "Current approval status"
        },
        "requestedAt": {
          "type": "string",
          "format": "date-time"
        },
        "respondedAt": {
          "type": "string",
          "format": "date-time"
        },
        "respondedBy": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "id": { "type": "string" },
            "name": { "type": "string" }
          }
        },
        "comment": {
          "type": "string",
          "description": "Comment from approver"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the approval request expires"
        },
        "requiredApprovals": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "Number of approvals required (from policy approvalConfig)"
        },
        "responses": {
          "type": "array",
          "description": "Individual approval responses for multi-party approval",
          "items": {
            "type": "object",
            "required": ["responderId", "decision", "respondedAt"],
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "responderType": { "type": "string" },
              "responderId": { "type": "string" },
              "responderName": { "type": "string" },
              "decision": { "type": "string", "enum": ["approve", "reject"] },
              "comment": { "type": "string" },
              "respondedAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["pending", "executed", "failed", "skipped", "cancelled"],
      "description": "Execution status of the action"
    },
    "execution": {
      "type": "object",
      "description": "Execution details if action was executed",
      "properties": {
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0,
          "description": "Execution duration in milliseconds"
        },
        "result": {
          "type": "object",
          "description": "Action result data",
          "additionalProperties": true
        },
        "error": {
          "type": "object",
          "description": "Error details if execution failed",
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "details": { "type": "object", "additionalProperties": true }
          }
        }
      }
    },
    "envelope": {
      "$ref": "action-envelope.schema.json",
      "description": "The original action envelope (embedded for completeness)"
    },
    "receiptHash": {
      "type": "string",
      "description": "SHA-256 hash of this receipt's core fields (envelopeId, timestamp, decision.outcome, status). Used for tamper detection."
    },
    "prevReceiptHash": {
      "type": "string",
      "description": "SHA-256 hash of the immediately preceding receipt, forming a hash chain for tamper-evident audit trails."
    },
    "metadata": {
      "type": "object",
      "description": "Additional receipt metadata",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
