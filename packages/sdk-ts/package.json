{
  "name": "@authensor/sdk",
  "version": "0.0.1",
  "description": "Authensor TypeScript SDK for agent builders",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "gen": "cd ../schemas/src && json2ts -i action-envelope.schema.json -o ../../sdk-ts/src/generated/action-envelope.ts && json2ts -i action-receipt.schema.json -o ../../sdk-ts/src/generated/action-receipt.ts && json2ts -i policy.schema.json -o ../../sdk-ts/src/generated/policy.ts"
  },
  "dependencies": {
    "@authensor/engine": "workspace:*",
    "@authensor/schemas": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "authensor",
    "sdk",
    "agent",
    "guardrails"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/authensor/authensor",
    "directory": "packages/sdk-ts"
  },
  "homepage": "https://github.com/authensor/authensor",
  "publishConfig": {
    "access": "public"
  }
}
