{
  "name": "@authensor/mcp-server",
  "version": "0.0.1",
  "description": "Authensor MCP Server - Stripe, GitHub, and HTTP tools with policy enforcement",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "authensor-mcp": "./dist/cli.js",
    "authensor-mcp-gateway": "./dist/gateway-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@authensor/engine": "workspace:*",
    "@authensor/schemas": "workspace:*",
    "ipaddr.js": "^2.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "stripe": "^20.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.1.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "authensor",
    "mcp",
    "model-context-protocol",
    "stripe",
    "github"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/authensor/authensor",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/authensor/authensor",
  "publishConfig": {
    "access": "public"
  }
}
