{
  "name": "authensor",
  "version": "0.0.1",
  "description": "The open-source safety stack for AI agents — one command to make your agent safe",
  "type": "module",
  "bin": {
    "authensor": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@authensor/engine": "workspace:*",
    "@authensor/schemas": "workspace:*"
  },
  "optionalDependencies": {
    "@authensor/aegis": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "authensor",
    "agent",
    "safety",
    "guardrails",
    "ai",
    "ai-safety",
    "agent-safety",
    "mcp",
    "mcp-security",
    "policy",
    "policy-engine",
    "agentic-ai",
    "action-authorization",
    "audit-trail",
    "approval-workflows",
    "human-in-the-loop",
    "owasp",
    "eu-ai-act",
    "content-safety",
    "prompt-injection",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/authensor/authensor",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/authensor/authensor",
  "publishConfig": {
    "access": "public"
  }
}
