# =============================================================================
# Authensor Control Plane - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# =============================================================================

# --- Database ----------------------------------------------------------------
# Password for the PostgreSQL instance. Change this in production.
POSTGRES_PASSWORD=authensor_dev

# Host port for PostgreSQL (container always uses 5432 internally).
POSTGRES_PORT=5432

# --- Server ------------------------------------------------------------------
# Host port for the Authensor API (container always uses 3000 internally).
PORT=3000

# --- Bootstrap ---------------------------------------------------------------
# One-time token used to create the first admin API key.
# Set this on first run, POST /keys with Authorization: Bearer <token>,
# then remove it.
AUTHENSOR_BOOTSTRAP_ADMIN_TOKEN=

# --- Aegis (content safety scanning) ----------------------------------------
# Enable Aegis content safety scanner. Disabled by default.
AUTHENSOR_AEGIS_ENABLED=false

# Aegis enforcement mode: block | redact | warn
AUTHENSOR_AEGIS_MODE=warn

# --- Sentinel (real-time monitoring) -----------------------------------------
# Sentinel is enabled by default. Set to false to disable.
AUTHENSOR_SENTINEL_ENABLED=true

# Webhook URL called when Sentinel detects an alert.
AUTHENSOR_SENTINEL_ALERT_WEBHOOK_URL=

# HMAC secret for signing Sentinel webhook payloads.
AUTHENSOR_SENTINEL_ALERT_WEBHOOK_SECRET=

# --- Policy evaluation -------------------------------------------------------
# Allow fallback to a default policy when no policy matches the request.
AUTHENSOR_ALLOW_FALLBACK_POLICY=false

# Policy ID used for shadow-mode evaluation (runs in parallel, does not block).
AUTHENSOR_SHADOW_POLICY_ID=

# Reject requests where the principal in the envelope does not match the API key.
AUTHENSOR_STRICT_PRINCIPAL_BINDING=false

# Skip auto-provisioning the default-safe policy on first boot.
AUTHENSOR_SKIP_DEFAULT_POLICY=

# Re-evaluate policy at claim time (TOCTOU protection). Set to false to disable.
AUTHENSOR_TOCTOU_REEVALUATE=true

# --- Transparency and compliance ---------------------------------------------
# Enable the transparency log endpoint.
AUTHENSOR_TRANSPARENCY_ENABLED=false

# --- Approval workflows ------------------------------------------------------
# Webhook URL called when a new approval request is created.
AUTHENSOR_APPROVAL_WEBHOOK_URL=

# HMAC secret for signing approval webhook payloads.
AUTHENSOR_APPROVAL_WEBHOOK_SECRET=

# Interval (ms) for the background loop that expires stale approval requests.
AUTHENSOR_APPROVAL_EXPIRY_INTERVAL_MS=60000

# --- Policy alert webhook ----------------------------------------------------
# Webhook URL called on policy deny decisions.
AUTHENSOR_POLICY_ALERT_WEBHOOK_URL=

# HMAC secret for signing policy alert webhook payloads.
AUTHENSOR_POLICY_ALERT_WEBHOOK_SECRET=

# --- Rate limiting -----------------------------------------------------------
# Requests per minute by role. Defaults shown.
AUTHENSOR_RL_INGEST_PER_MIN=120
AUTHENSOR_RL_EXECUTOR_PER_MIN=60
AUTHENSOR_RL_ADMIN_PER_MIN=120

# Webhook URL called when a rate limit is hit.
AUTHENSOR_RATE_LIMIT_WEBHOOK_URL=

# HMAC secret for signing rate-limit webhook payloads.
AUTHENSOR_RATE_LIMIT_WEBHOOK_SECRET=

# --- Request/response size limits --------------------------------------------
# Maximum request body size in bytes.
AUTHENSOR_MAX_REQUEST_BYTES=256000

# Maximum result body size in bytes.
AUTHENSOR_MAX_RESULT_BYTES=128000

# --- Session management ------------------------------------------------------
# Session time-to-live in milliseconds.
AUTHENSOR_SESSION_TTL_MS=3600000

# Maximum number of history entries per session.
AUTHENSOR_SESSION_MAX_HISTORY=1000

# --- Receipt claims ----------------------------------------------------------
# Time-to-live in seconds for receipt claim tokens.
AUTHENSOR_CLAIM_TTL_SECONDS=30

# --- Telemetry ---------------------------------------------------------------
# Enable OpenTelemetry tracing export.
AUTHENSOR_OTEL_ENABLED=false

# --- Proxy -------------------------------------------------------------------
# Trust X-Forwarded-For headers (set to true behind a reverse proxy).
TRUST_PROXY=false

# --- Sandbox mode ------------------------------------------------------------
# Set to bypass auth for local development/testing (never use in production).
AUTHENSOR_SANDBOX_MODE=
